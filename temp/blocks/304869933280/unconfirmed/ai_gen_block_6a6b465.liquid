{% doc %}
  @prompt
    a dropdwon title started a with a icon
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dropdown-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dropdown-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.header_background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-dropdown-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.header_hover_background_color }};
  }

  .ai-dropdown-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-dropdown-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-dropdown-title-{{ ai_gen_id }} {
    flex-grow: 1;
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_font_weight }};
  }

  .ai-dropdown-arrow-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.arrow_color }};
    transition: transform 0.3s ease;
  }

  .ai-dropdown-arrow-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-dropdown-{{ ai_gen_id }}.active .ai-dropdown-arrow-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-dropdown-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-dropdown-content-inner-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.content_background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-top: none;
    border-radius: 0 0 {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px;
  }

  .ai-dropdown-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.content_font_size }}px;
    color: {{ block.settings.content_color }};
    line-height: 1.6;
  }
{% endstyle %}

<dropdown-block-{{ ai_gen_id }} class="ai-dropdown-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <button
    class="ai-dropdown-header-{{ ai_gen_id }}"
    aria-expanded="false"
    aria-controls="ai-dropdown-content-{{ ai_gen_id }}"
  >
    <span class="ai-dropdown-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_type == 'star' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      {% elsif block.settings.icon_type == 'heart' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      {% elsif block.settings.icon_type == 'info' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
      {% elsif block.settings.icon_type == 'check' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      {% elsif block.settings.icon_type == 'gift' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 12 20 22 4 22 4 12"></polyline>
          <rect x="2" y="7" width="20" height="5"></rect>
          <line x1="12" y1="22" x2="12" y2="7"></line>
          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
        </svg>
      {% elsif block.settings.icon_type == 'tag' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
          <line x1="7" y1="7" x2="7.01" y2="7"></line>
        </svg>
      {% elsif block.settings.icon_type == 'bell' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
      {% endif %}
    </span>

    <h3 class="ai-dropdown-title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>

    <span class="ai-dropdown-arrow-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </span>
  </button>

  <div class="ai-dropdown-content-{{ ai_gen_id }}" id="ai-dropdown-content-{{ ai_gen_id }}">
    <div class="ai-dropdown-content-inner-{{ ai_gen_id }}">
      <div class="ai-dropdown-text-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    </div>
  </div>
</dropdown-block-{{ ai_gen_id }}>

<script>
  (function() {
    class DropdownBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('.ai-dropdown-header-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-dropdown-content-{{ ai_gen_id }}');
        this.contentInner = this.querySelector('.ai-dropdown-content-inner-{{ ai_gen_id }}');
        
        this.button.addEventListener('click', () => this.toggle());
        
        if ({{ block.settings.open_by_default | json }}) {
          this.open();
        }
      }

      toggle() {
        if (this.classList.contains('active')) {
          this.close();
        } else {
          this.open();
        }
      }

      open() {
        this.classList.add('active');
        this.button.setAttribute('aria-expanded', 'true');
        this.content.style.maxHeight = this.contentInner.scrollHeight + 'px';
      }

      close() {
        this.classList.remove('active');
        this.button.setAttribute('aria-expanded', 'false');
        this.content.style.maxHeight = '0';
      }
    }

    customElements.define('dropdown-block-{{ ai_gen_id }}', DropdownBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Dropdown with icon",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Click to expand"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        {
          "value": "info",
          "label": "Info"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "heart",
          "label": "Heart"
        },
        {
          "value": "check",
          "label": "Check"
        },
        {
          "value": "gift",
          "label": "Gift"
        },
        {
          "value": "tag",
          "label": "Tag"
        },
        {
          "value": "bell",
          "label": "Bell"
        }
      ],
      "default": "info"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Spacing from title",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>This is the dropdown content. Add your text here.</p>"
    },
    {
      "type": "range",
      "id": "content_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "content_background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "header",
      "content": "Header style"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "header_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_hover_background_color",
      "label": "Hover background color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Dropdown with icon"
    }
  ]
}
{% endschema %}
